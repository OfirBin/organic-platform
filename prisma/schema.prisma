// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Question {
  id         String   @id @default(uuid())
  text       String
  imageUrl   String?
  answer     String
  topic      String
  sourceExam String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  distractors String?
  stat       CardStat?
}

model CardStat {
  id             String    @id @default(uuid())
  questionId     String    @unique
  question       Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)
  timesStudied   Int       @default(0)
  timesCorrect   Int       @default(0)
  timesIncorrect Int       @default(0)
  easeFactor     Float     @default(2.5)
  interval       Int       @default(0)
  nextReview     DateTime?
  lastReviewedAt DateTime?
}

model StudySession {
  id           String    @id @default(uuid())
  startTime    DateTime  @default(now())
  endTime      DateTime?
  cardsStudied Int       @default(0)
}

// --------------------------------------
// 4. KNOWLEDGE BASE (Lectures & Notes)
// --------------------------------------
model Document {
  id        String   @id @default(cuid())
  title     String   // e.g., "Lecture 5 - Reaction Mechanisms"
  type      String   // e.g., "Lecture" or "Exam Solution"
  createdAt DateTime @default(now())
  
  chunks    Chunk[]
}

model Chunk {
  id         String   @id @default(cuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  
  pageNumber Int
  content    String   // The AI-extracted text and mechanism descriptions
  imageUrl   String?  // Optional: A direct link to an image of the slide
}
